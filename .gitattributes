# Preserve binary assets exactly. Without this, on machines with
# core.autocrlf=true (Git for Windows default) every binary whose byte
# stream happens to contain an LF (0x0A) -- PDFs, PNGs, JPEGs, TTFs --
# gets silently rewritten on checkout. For Ego.Pdf.Test/Baselines/*.pdf
# that would change the SHA-256 against which VisualBaselineTests
# asserts.
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# Baseline hashes and other config-style ASCII text: pin to LF so the
# same file is byte-identical regardless of the developer's platform.
*.sha256 text eol=lf

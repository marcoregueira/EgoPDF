<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>Ego.PDF</RootNamespace>
    <AssemblyName>Ego.PdfCore</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;0162;0168;0219;0436;CS8618;CS8625;CS8604;CS0618</NoWarn>
  </PropertyGroup>

  <!-- NuGet package metadata -->
  <PropertyGroup>
    <PackageId>EgoPDF.Generator</PackageId>
    <!-- Last MyGet-built version was 2.0.107, so any locally-published
         package needs to sort higher. 2.1.0 reflected the multi-target
         move (net8.0;net9.0, no more netstandard2.0) plus the embedded
         TrueType descriptor fixes. 2.2.0 adds the agent-friendly
         primitives (Rect, Row, Stack, Panel, PanelStyle, PushState,
         PushPos, Bounds) and fixes GetStringWidth / GoBack. -->
    <Version>2.2.0</Version>
    <AssemblyVersion>2.2.0.0</AssemblyVersion>
    <FileVersion>2.2.0.0</FileVersion>
    <Authors>Marco Antonio Regueira</Authors>
    <Company>Marco Antonio Regueira</Company>
    <Copyright>Copyright (c) 2017-2026 Marco Antonio Regueira</Copyright>
    <Description>FPDF-based PDF generator for .NET. Embeds TrueType fonts with valid PDF descriptors (Acrobat-strict compatible), draws text / lines / rectangles / cells / multi-cell / images, and exposes the classic FPDF API on net8.0 and net9.0. Pair with EgoPDF.Barcodes to render Zebra ZPL II labels.</Description>
    <PackageTags>pdf;fpdf;generator;portable;net8;net9</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/marcoregueira/egopdf</PackageProjectUrl>
    <RepositoryUrl>https://github.com/marcoregueira/egopdf.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReleaseNotes>2.2.0: layout primitives and scope helpers. New Rect value type plus FPdf.Row / Stack / Panel for composing pages without (x + width + gap) arithmetic. PanelStyle records capture frame + title looks as reusable data. PushState / PushPos return IDisposable scopes that auto-restore font, colour, line-width and cursor state. Bounds() returns the printable area as a Rect. Bug fixes: GetStringWidth falls back to the "A" glyph width for missing characters instead of throwing KeyNotFoundException; GoBack(GoBackMode) now honours the X / Y / Both selector. Fully additive over 2.1.0.</PackageReleaseNotes>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\LICENSE" Pack="true" PackagePath="\" />
    <!-- NOTICE acknowledges FPDF; only shipped with the Generator
         package because the Zpl package contains no FPDF-derived code. -->
    <None Include="..\NOTICE"  Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="3.116.1" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

</Project>
